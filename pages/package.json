{
  "name": "@ossy/pages",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ossy-se/packages.git"
  },
  "description": "SaaS page templates and layouts: auth (login, signup, forgot password, verify email), pricing, settings, dashboard, 404, landing page, resume",
  "version": "0.10.1",
  "source": "src/index.js",
  "type": "module",
  "module": "build/index.js",
  "author": "Ossy <yourfriends@ossy.se> (https://ossy.se)",
  "license": "MIT",
  "scripts": {
    "build": "rollup -c rollup.config.js",
    "build:addons2": "rollup -c ./src/addons/rollup.config.js",
    "build:addons": "babel --no-babelrc babelrc.addons.js ./src/addons --out-dir ./storybook",
    "test": "",
    "lint": "eslint '**/*.(js|jsx)'"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@ossy/themes": "^0.10.1",
    "moment": "^2.29.4"
  },
  "peerDependencies": {
    "@ossy/design-system": ">=0.0.1 <1.0.0",
    "react": ">=19.0.0 <20.0.0",
    "react-dom": ">=19.0.0 <20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "files": [
    "/build",
    "README.md"
  ]
}
